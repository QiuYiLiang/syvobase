{
  "name": "@syvobase/design",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite build -w",
    "build": "vite build",
    "build:npm": "cross-env BUILD_MODE=npm vite build",
    "test": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "dev:docs": "storybook dev -p 7000 --no-open",
    "build:docs": "storybook build",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "update:latest": "pnpm update --latest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./base.css": "./dist/ui.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.es.js",
      "require": "./dist/*.cjs.js"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
