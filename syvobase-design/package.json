    "@platejs/basic-nodes": "^52.0.11",
    "@platejs/basic-styles": "^52.0.11",
    "@platejs/code-block": "^52.0.11",
    "@platejs/indent": "^52.0.11",
    "@platejs/link": "^52.0.11",
    "@platejs/list": "^52.0.11",
    "@platejs/list-classic": "^52.0.11",
    "@platejs/markdown": "^52.1.0",
    "@platejs/media": "^52.0.11",
    "@platejs/table": "^52.0.11",
    "@platejs/toggle": "^52.0.11",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@syvobase/utils": "^0.0.1",
    "@types/dagre": "^0.7.53",
    "antd": "^6.2.0",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "platejs": "^52.0.17",
    "rc-picker": "^4.11.3",
    "rc-resize-observer": "^1.4.3",
    "react": "^19.2.3",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-split-pane": "^3.0.5",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "slate": "^0.120.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.0.1",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.7",
    "@types/react": "^19.2.8",
