{
  "name": "@syvobase/schema",
  "private": true,
  "version": "0.0.0",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite build -w",
    "build": "vite build",
    "test": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "update:latest": "pnpm update --latest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.7",
    "@types/react": "^19.2.8",
    "@vitest/coverage-v8": "^4.0.17",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "8.0.0-beta.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17"
  }
}
