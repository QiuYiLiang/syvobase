{
  "name": "@syvobase/utils",
  "private": true,
  "version": "0.0.0",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite build -w",
    "build": "vite build",
    "test": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "update:latest": "pnpm update --latest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.es.js",
      "require": "./dist/*.cjs.js"
    }
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "lodash-es": "^4.17.22"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.0.7",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "8.0.0-beta.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17"
  }
}
